{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": false,
    "strict": true,
    "noEmitOnError": false,
    "skipLibCheck": true
  },
  "include": ["src"]
}